# ============================================================
# Local Genius — Environment Configuration
# ============================================================
# Copy this file to .env and adjust values for your setup.
#   cp .env.example .env
# ============================================================

# --- The Brain (LLM Engine) ---
OLLAMA_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434

# --- Memory (ChromaDB) ---
CHROMA_DB_PATH=./chroma_db

# --- Safety Monitor ---
SAFETY_LOG_PATH=./safety_monitor.log

# --- Orchestrator ---
MAX_RETRIES=3

# --- Gateway (MQTT / Hardware) ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_ENABLED=false

# --- General ---
LOG_LEVEL=INFO
